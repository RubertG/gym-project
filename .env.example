# Supabase
# Variables PUBLIC_* están disponibles en el browser (client + server)
PUBLIC_SUPABASE_URL=https://<project>.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-public-key>

# Variables sin prefijo solo están disponibles en el servidor (secretos)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Cloudflare R2 (API compatible S3)
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=iron-track-exercises
CLOUDFLARE_R2_ACCESS_KEY_ID=<r2-access-key-id>
CLOUDFLARE_R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
CLOUDFLARE_R2_PUBLIC_URL_BASE=https://pub-aa0db9342631451289ced5c0b814cf9f.r2.dev

# Control de propuestas de ejercicios: users | admins | none
EXERCISE_PROPOSAL_MODE=users
