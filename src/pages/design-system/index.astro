---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.tsx';
import Input from '../../components/ui/Input.tsx';
import GlowEffect from '../../components/ui/GlowEffect.tsx';
import Card from '../../components/ui/Card.tsx';

const primaryScale = [
    { label: '50', class: 'bg-primary-50', text: 'text-black' },
    { label: '100', class: 'bg-primary-100', text: 'text-black' },
    { label: '200', class: 'bg-primary-200', text: 'text-black' },
    { label: '300', class: 'bg-primary-300', text: 'text-black' },
    { label: '400', class: 'bg-primary-400', text: 'text-black' },
    { label: '500', class: 'bg-primary-500', text: 'text-black' },
    { label: '600', class: 'bg-primary-600', text: 'text-white' },
    { label: '700', class: 'bg-primary-700', text: 'text-white' },
    { label: '800', class: 'bg-primary-800', text: 'text-white' },
    { label: '900', class: 'bg-primary-900', text: 'text-white' },
    { label: '950', class: 'bg-primary-950', text: 'text-white' },
];

const secondaryScale = [
    { label: '50', class: 'bg-secondary-50', text: 'text-black' },
    { label: '100', class: 'bg-secondary-100', text: 'text-black' },
    { label: '200', class: 'bg-secondary-200', text: 'text-black' },
    { label: '300', class: 'bg-secondary-300', text: 'text-black' },
    { label: '400', class: 'bg-secondary-400', text: 'text-black' },
    { label: '500', class: 'bg-secondary-500', text: 'text-white' },
    { label: '600', class: 'bg-secondary-600', text: 'text-white' },
    { label: '700', class: 'bg-secondary-700', text: 'text-white' },
    { label: '800', class: 'bg-secondary-800', text: 'text-white' },
    { label: '900', class: 'bg-secondary-900', text: 'text-white' },
    { label: '950', class: 'bg-secondary-950', text: 'text-white' },
];

const backgroundScale = [
    { label: '50', class: 'bg-background-50', text: 'text-white' },
    { label: '100', class: 'bg-background-100', text: 'text-white' },
    { label: '200', class: 'bg-background-200', text: 'text-white' },
    { label: '300', class: 'bg-background-300', text: 'text-white' },
    { label: '400', class: 'bg-background-400', text: 'text-white' },
    { label: '500', class: 'bg-background-500', text: 'text-white' },
    { label: '600', class: 'bg-background-600', text: 'text-white' },
    { label: '700', class: 'bg-background-700', text: 'text-white' },
    { label: '800', class: 'bg-background-800', text: 'text-white' },
    { label: '900', class: 'bg-background-900', text: 'text-white' },
    { label: '950', class: 'bg-background-950', text: 'text-white' },
];

const wordScale = [
    { label: '50', class: 'text-word-50' },
    { label: '100', class: 'text-word-100' },
    { label: '200', class: 'text-word-200' },
    { label: '300', class: 'text-word-300' },
    { label: '400', class: 'text-word-400' },
];
---

<Layout title="IRON TRACK - Design System Palette">
    <main class="bg-background-900 min-h-screen p-4 md:p-6 lg:p-8">
        <!-- Nav -->
        <nav class="border-secondary-800 mb-6 flex gap-4 border-b pb-4 md:mb-8">
            <a
                href="/design-system"
                class="text-primary-400 font-mono text-xs tracking-widest uppercase md:text-sm"
            >
                Palette
            </a>
            <a
                href="/design-system/components"
                class="text-word-400 hover:text-word-200 font-mono text-xs tracking-widest uppercase transition-colors md:text-sm"
            >
                Components
            </a>
        </nav>

        <!-- Header -->
        <header class="animate-fade-in-up mb-8 md:mb-12">
            <h1
                class="font-display text-primary-400 text-3xl font-bold tracking-tighter md:text-4xl lg:text-5xl"
            >
                VOLTAGE INDUSTRIAL
            </h1>
            <p class="font-body text-word-200 mt-2 text-lg md:text-xl">
                Design System Palette — IRON TRACK
            </p>
        </header>

        <!-- Color Scales -->
        <section
            class="animate-fade-in-up mb-12 space-y-8 md:mb-16 md:space-y-12"
        >
            <!-- Primary -->
            <div>
                <h2
                    class="font-display text-primary-400 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
                >
                    Primary Scale
                </h2>
                <div
                    class="grid grid-cols-5 gap-1 sm:grid-cols-7 md:grid-cols-9 md:gap-2 lg:grid-cols-11"
                >
                    {
                        primaryScale.map((item) => (
                            <div class="flex flex-col items-center">
                                <div
                                    class={`${item.class} ${item.text} flex h-10 w-full items-center justify-center border border-white/10 font-mono text-xs font-bold md:h-16 md:text-sm`}
                                >
                                    {item.label}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- Secondary -->
            <div>
                <h2
                    class="font-display text-secondary-300 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
                >
                    Secondary Scale
                </h2>
                <div
                    class="grid grid-cols-5 gap-1 sm:grid-cols-7 md:grid-cols-9 md:gap-2 lg:grid-cols-11"
                >
                    {
                        secondaryScale.map((item) => (
                            <div class="flex flex-col items-center">
                                <div
                                    class={`${item.class} ${item.text} flex h-10 w-full items-center justify-center border border-white/10 font-mono text-xs font-bold md:h-16 md:text-sm`}
                                >
                                    {item.label}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- Background -->
            <div>
                <h2
                    class="font-display text-word-300 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
                >
                    Background Scale
                </h2>
                <div
                    class="grid grid-cols-5 gap-1 sm:grid-cols-7 md:grid-cols-9 md:gap-2 lg:grid-cols-11"
                >
                    {
                        backgroundScale.map((item) => (
                            <div class="flex flex-col items-center">
                                <div
                                    class={`${item.class} ${item.text} flex h-10 w-full items-center justify-center border border-white/10 font-mono text-xs font-bold md:h-16 md:text-sm`}
                                >
                                    {item.label}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Word Colors (Text) -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Word Scale (Text Colors)
            </h2>
            <Card className="space-y-4 p-4 md:p-6 lg:p-8">
                {
                    wordScale.map((item) => (
                        <div class="flex items-center gap-4">
                            <span
                                class={`font-mono text-xs md:text-sm ${item.class} w-16 md:w-20`}
                            >
                                {item.label}
                            </span>
                            <p class={`text-base md:text-xl ${item.class}`}>
                                The quick brown fox jumps over the lazy dog
                            </p>
                        </div>
                    ))
                }
            </Card>
        </section>

        <!-- Typography Samples -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Typography Samples
            </h2>
            <div class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
                <!-- Display -->
                <Card className="p-4 md:p-6">
                    <span
                        class="text-word-400 font-mono text-xs tracking-widest uppercase"
                        >Display</span
                    >
                    <h3
                        class="font-display text-primary-400 mt-2 text-3xl font-bold md:text-4xl"
                    >
                        IRON<br />TRACK
                    </h3>
                    <p
                        class="font-display text-word-300 mt-4 text-base md:text-lg"
                    >
                        Space Grotesk — Bold & Tight
                    </p>
                </Card>

                <!-- Body -->
                <Card className="p-4 md:p-6">
                    <span
                        class="text-word-400 font-mono text-xs tracking-widest uppercase"
                        >Body</span
                    >
                    <p
                        class="font-body text-word-200 mt-2 text-base leading-relaxed md:text-lg"
                    >
                        Inter is a clean and highly legible typeface designed
                        for screens. It pairs perfectly with the industrial
                        aesthetic of IRON TRACK.
                    </p>
                    <p class="font-body text-word-300 mt-4 text-xs md:text-sm">
                        Used for all body copy, labels, and UI text.
                    </p>
                </Card>

                <!-- Mono -->
                <Card className="p-4 md:p-6">
                    <span
                        class="text-word-400 font-mono text-xs tracking-widest uppercase"
                        >Mono</span
                    >
                    <p
                        class="text-word-200 mt-2 font-mono text-base md:text-lg"
                    >
                        SETS: 4<br />
                        REPS: 8-12<br />
                        WEIGHT: 82.5 KG
                    </p>
                    <p class="text-word-300 mt-4 font-mono text-xs md:text-sm">
                        JetBrains Mono — Data & Labels
                    </p>
                </Card>
            </div>
        </section>

        <!-- Component Showcase (Static) -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Static Component Showcase
            </h2>
            <Card className="space-y-8 p-4 md:p-6 lg:p-8">
                <!-- Buttons -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Buttons
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" client:load
                            >Primary Action</Button
                        >
                        <Button variant="secondary" client:load
                            >Secondary Action</Button
                        >
                    </div>
                </div>

                <!-- Input -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Input Field
                    </h3>
                    <Input
                        type="text"
                        placeholder="Enter your workout name..."
                        client:load
                    />
                </div>

                <!-- Glow Effect -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Glow Effect
                    </h3>
                    <GlowEffect
                        color="primary"
                        intensity="md"
                        className="bg-primary-400 inline-block p-4 font-mono font-bold text-black md:p-6"
                    >
                        GLOW PRIMARY
                    </GlowEffect>
                </div>

                <!-- Card Glass -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Glass Card
                    </h3>
                    <Card className="max-w-md p-4 md:p-6">
                        <h4
                            class="font-display text-primary-400 text-lg font-bold md:text-xl"
                        >
                            Workout Session
                        </h4>
                        <p
                            class="font-body text-word-300 mt-2 text-sm md:text-base"
                        >
                            This is a glass card with backdrop blur and a subtle
                            lime border. Used for panels and floating UI
                            elements.
                        </p>
                    </Card>
                </div>
            </Card>
        </section>

        <!-- Footer -->
        <footer
            class="border-secondary-800 border-t px-4 pt-6 text-center md:px-0 md:pt-8"
        >
            <p class="text-word-400 font-mono text-xs md:text-sm">
                IRON TRACK — Voltage Industrial Design System v1.0
            </p>
        </footer>
    </main>
</Layout>
