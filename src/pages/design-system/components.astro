---
import Layout from '@/layouts/Layout.astro';
import Input from '@/components/ui/Input.tsx';
import GlowEffect from '@/components/ui/GlowEffect.tsx';
import Card from '@/components/ui/Card.tsx';
import { Button } from '@/components';
---

<Layout title="IRON TRACK - Componentes">
    <main class="bg-background-900 min-h-screen p-4 md:p-6 lg:p-8">
        <!-- Nav -->
        <nav class="border-secondary-800 mb-6 flex gap-4 border-b pb-4 md:mb-8">
            <a
                href="/design-system"
                class="text-word-400 hover:text-word-200 font-mono text-xs tracking-widest uppercase transition-colors md:text-sm"
            >
                Paleta
            </a>
            <a
                href="/design-system/components"
                class="text-primary-400 font-mono text-xs tracking-widest uppercase md:text-sm"
            >
                Componentes
            </a>
        </nav>

        <!-- Header -->
        <header class="animate-fade-in-up mb-8 md:mb-12">
            <h1
                class="font-display text-primary-400 text-3xl font-bold tracking-tighter md:text-4xl lg:text-5xl"
            >
                COMPONENTES
            </h1>
            <p class="font-body text-word-200 mt-2 text-lg md:text-xl">
                Componentes React Reutilizables — IRON TRACK
            </p>
        </header>

        <!-- Button Component Section -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Botón
            </h2>
            <Card className="space-y-8 p-4 md:p-6 lg:p-8">
                <!-- Variants -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Variantes
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" client:load>Primario</Button>
                        <Button variant="secondary" client:load
                            >Secundario</Button
                        >
                        <Button variant="ghost" client:load>Ghost</Button>
                        <Button variant="danger" client:load>Peligro</Button>
                    </div>
                </div>

                <!-- Variants (Light Surface) -->
                <div class="bg-secondary-50 space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Variantes — Superficie Clara
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" surface="light" client:load
                            >Primario</Button
                        >
                        <Button variant="secondary" surface="light" client:load
                            >Secundario</Button
                        >
                        <Button variant="ghost" surface="light" client:load
                            >Ghost</Button
                        >
                        <Button variant="danger" surface="light" client:load
                            >Peligro</Button
                        >
                    </div>
                </div>

                <!-- Sizes -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Tamaños
                    </h3>
                    <div class="flex flex-wrap items-center gap-4">
                        <Button variant="primary" size="sm" client:load
                            >Pequeño</Button
                        >
                        <Button variant="primary" size="md" client:load
                            >Mediano</Button
                        >
                        <Button variant="primary" size="lg" client:load
                            >Grande</Button
                        >
                    </div>
                </div>

                <!-- Sizes (Light Surface) -->
                <div class="bg-secondary-50 space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Tamaños — Superficie Clara
                    </h3>
                    <div class="flex flex-wrap items-center gap-4">
                        <Button
                            variant="primary"
                            size="sm"
                            surface="light"
                            client:load>Pequeño</Button
                        >
                        <Button
                            variant="primary"
                            size="md"
                            surface="light"
                            client:load>Mediano</Button
                        >
                        <Button
                            variant="primary"
                            size="lg"
                            surface="light"
                            client:load>Grande</Button
                        >
                    </div>
                </div>

                <!-- States -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Estados
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" client:load
                            >Predeterminado</Button
                        >
                        <Button variant="primary" disabled client:load>
                            Desactivado
                        </Button>
                        <Button variant="primary" glow client:load>
                            Con Glow
                        </Button>
                    </div>
                </div>

                <!-- States (Light Surface) -->
                <div class="bg-secondary-50 space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Estados — Superficie Clara
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" surface="light" client:load
                            >Predeterminado</Button
                        >
                        <Button
                            variant="primary"
                            surface="light"
                            disabled
                            client:load
                        >
                            Desactivado
                        </Button>
                        <Button
                            variant="primary"
                            surface="light"
                            glow
                            client:load
                        >
                            Con Glow
                        </Button>
                    </div>
                </div>
            </Card>
        </section>

        <!-- Input Component Section -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Campo de Texto
            </h2>
            <Card className="space-y-8 p-4 md:p-6 lg:p-8">
                <!-- Default -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Predeterminado
                    </h3>
                    <Input
                        type="text"
                        label="Nombre del Entrenamiento"
                        placeholder="Ingresa el nombre de tu entrenamiento..."
                        client:load
                    />
                </div>

                <!-- Default (Light Surface) -->
                <div class="bg-secondary-50 max-w-md space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Predeterminado — Superficie Clara
                    </h3>
                    <Input
                        type="text"
                        label="Nombre del Entrenamiento"
                        placeholder="Ingresa el nombre de tu entrenamiento..."
                        surface="light"
                        client:load
                    />
                </div>

                <!-- With Error -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Con Error
                    </h3>
                    <Input
                        type="email"
                        label="Correo Electrónico"
                        placeholder="tu@correo.com"
                        error="Por favor, ingresa un correo electrónico válido"
                        value="correo-invalido"
                        isRequired
                        client:load
                    />
                </div>

                <!-- With Error (Light Surface) -->
                <div class="bg-secondary-50 max-w-md space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Con Error — Superficie Clara
                    </h3>
                    <Input
                        type="email"
                        label="Correo Electrónico"
                        placeholder="tu@correo.com"
                        error="Por favor, ingresa un correo electrónico válido"
                        value="correo-invalido"
                        isRequired
                        surface="light"
                        client:load
                    />
                </div>

                <!-- Ghost Variant -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Variante Ghost
                    </h3>
                    <Input
                        type="text"
                        placeholder="Buscar ejercicios..."
                        variant="ghost"
                        client:load
                    />
                </div>

                <!-- Ghost Variant (Light Surface) -->
                <div class="bg-secondary-50 max-w-md space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Variante Ghost — Superficie Clara
                    </h3>
                    <Input
                        type="text"
                        placeholder="Buscar ejercicios..."
                        variant="ghost"
                        surface="light"
                        client:load
                    />
                </div>
            </Card>
        </section>

        <!-- Glow Effect Section -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Efecto Glow
            </h2>
            <Card className="space-y-8 p-4 md:p-6 lg:p-8">
                <div class="flex flex-wrap gap-8">
                    <div class="space-y-2 text-center">
                        <GlowEffect
                            color="primary"
                            intensity="sm"
                            className="bg-primary-400 p-4 font-mono font-bold text-black md:p-6"
                        >
                            SM
                        </GlowEffect>
                        <span class="text-word-400 font-mono text-xs"
                            >Pequeño</span
                        >
                    </div>
                    <div class="space-y-2 text-center">
                        <GlowEffect
                            color="primary"
                            intensity="md"
                            className="bg-primary-400 p-4 font-mono font-bold text-black md:p-6"
                        >
                            MD
                        </GlowEffect>
                        <span class="text-word-400 font-mono text-xs"
                            >Mediano</span
                        >
                    </div>
                    <div class="space-y-2 text-center">
                        <GlowEffect
                            color="primary"
                            intensity="lg"
                            className="bg-primary-400 p-4 font-mono font-bold text-black md:p-6"
                        >
                            LG
                        </GlowEffect>
                        <span class="text-word-400 font-mono text-xs"
                            >Grande</span
                        >
                    </div>
                </div>
            </Card>
        </section>

        <!-- Footer -->
        <footer
            class="border-secondary-800 border-t px-4 pt-6 text-center md:px-0 md:pt-8"
        >
            <p class="text-word-400 font-mono text-xs md:text-sm">
                IRON TRACK — Voltage Industrial Design System v1.0
            </p>
        </footer>
    </main>
</Layout>
