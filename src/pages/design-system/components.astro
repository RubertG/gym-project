---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.tsx';
import Input from '../../components/ui/Input.tsx';
import GlowEffect from '../../components/ui/GlowEffect.tsx';
import Card from '../../components/ui/Card.tsx';
---

<Layout title="IRON TRACK - Components">
    <main class="bg-background-900 min-h-screen p-4 md:p-6 lg:p-8">
        <!-- Nav -->
        <nav class="border-secondary-800 mb-6 flex gap-4 border-b pb-4 md:mb-8">
            <a
                href="/design-system"
                class="text-word-400 hover:text-word-200 font-mono text-xs tracking-widest uppercase transition-colors md:text-sm"
            >
                Palette
            </a>
            <a
                href="/design-system/components"
                class="text-primary-400 font-mono text-xs tracking-widest uppercase md:text-sm"
            >
                Components
            </a>
        </nav>

        <!-- Header -->
        <header class="animate-fade-in-up mb-8 md:mb-12">
            <h1
                class="font-display text-primary-400 text-3xl font-bold tracking-tighter md:text-4xl lg:text-5xl"
            >
                COMPONENTS
            </h1>
            <p class="font-body text-word-200 mt-2 text-lg md:text-xl">
                Reusable React UI Components — IRON TRACK
            </p>
        </header>

        <!-- Button Component Section -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Button
            </h2>
            <Card className="space-y-8 p-4 md:p-6 lg:p-8">
                <!-- Variants -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Variants
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" client:load>Primary</Button>
                        <Button variant="secondary" client:load
                            >Secondary</Button
                        >
                        <Button variant="ghost" client:load>Ghost</Button>
                        <Button variant="danger" client:load>Danger</Button>
                    </div>
                </div>

                <!-- Variants (Light Surface) -->
                <div class="bg-secondary-50 space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Variants — Light Surface
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" surface="light" client:load
                            >Primary</Button
                        >
                        <Button variant="secondary" surface="light" client:load
                            >Secondary</Button
                        >
                        <Button variant="ghost" surface="light" client:load
                            >Ghost</Button
                        >
                        <Button variant="danger" surface="light" client:load
                            >Danger</Button
                        >
                    </div>
                </div>

                <!-- Sizes -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Sizes
                    </h3>
                    <div class="flex flex-wrap items-center gap-4">
                        <Button variant="primary" size="sm" client:load
                            >Small</Button
                        >
                        <Button variant="primary" size="md" client:load
                            >Medium</Button
                        >
                        <Button variant="primary" size="lg" client:load
                            >Large</Button
                        >
                    </div>
                </div>

                <!-- Sizes (Light Surface) -->
                <div class="bg-secondary-50 space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Sizes — Light Surface
                    </h3>
                    <div class="flex flex-wrap items-center gap-4">
                        <Button
                            variant="primary"
                            size="sm"
                            surface="light"
                            client:load>Small</Button
                        >
                        <Button
                            variant="primary"
                            size="md"
                            surface="light"
                            client:load>Medium</Button
                        >
                        <Button
                            variant="primary"
                            size="lg"
                            surface="light"
                            client:load>Large</Button
                        >
                    </div>
                </div>

                <!-- States -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        States
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" client:load>Default</Button>
                        <Button variant="primary" disabled client:load>
                            Disabled
                        </Button>
                        <Button variant="primary" glow client:load>
                            With Glow
                        </Button>
                    </div>
                </div>

                <!-- States (Light Surface) -->
                <div class="bg-secondary-50 space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        States — Light Surface
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <Button variant="primary" surface="light" client:load
                            >Default</Button
                        >
                        <Button
                            variant="primary"
                            surface="light"
                            disabled
                            client:load
                        >
                            Disabled
                        </Button>
                        <Button
                            variant="primary"
                            surface="light"
                            glow
                            client:load
                        >
                            With Glow
                        </Button>
                    </div>
                </div>
            </Card>
        </section>

        <!-- Input Component Section -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Input
            </h2>
            <Card className="space-y-8 p-4 md:p-6 lg:p-8">
                <!-- Default -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Default
                    </h3>
                    <Input
                        type="text"
                        label="Workout Name"
                        placeholder="Enter your workout name..."
                        client:load
                    />
                </div>

                <!-- Default (Light Surface) -->
                <div class="bg-secondary-50 max-w-md space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Default — Light Surface
                    </h3>
                    <Input
                        type="text"
                        label="Workout Name"
                        placeholder="Enter your workout name..."
                        surface="light"
                        client:load
                    />
                </div>

                <!-- With Error -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        With Error
                    </h3>
                    <Input
                        type="email"
                        label="Email"
                        placeholder="your@email.com"
                        error="Please enter a valid email address"
                        value="invalid-email"
                        isRequired
                        client:load
                    />
                </div>

                <!-- With Error (Light Surface) -->
                <div class="bg-secondary-50 max-w-md space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        With Error — Light Surface
                    </h3>
                    <Input
                        type="email"
                        label="Email"
                        placeholder="your@email.com"
                        error="Please enter a valid email address"
                        value="invalid-email"
                        isRequired
                        surface="light"
                        client:load
                    />
                </div>

                <!-- Ghost Variant -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Ghost Variant
                    </h3>
                    <Input
                        type="text"
                        placeholder="Search exercises..."
                        variant="ghost"
                        client:load
                    />
                </div>

                <!-- Ghost Variant (Light Surface) -->
                <div class="bg-secondary-50 max-w-md space-y-4 rounded-lg p-4">
                    <h3
                        class="text-secondary-600 font-mono text-xs tracking-widest uppercase md:text-sm"
                    >
                        Ghost Variant — Light Surface
                    </h3>
                    <Input
                        type="text"
                        placeholder="Search exercises..."
                        variant="ghost"
                        surface="light"
                        client:load
                    />
                </div>
            </Card>
        </section>

        <!-- Glow Effect Section -->
        <section class="animate-fade-in-up mb-12 md:mb-16">
            <h2
                class="font-display text-word-100 mb-3 text-xl font-bold tracking-widest uppercase md:mb-4 md:text-2xl"
            >
                Glow Effect
            </h2>
            <Card className="space-y-8 p-4 md:p-6 lg:p-8">
                <div class="flex flex-wrap gap-8">
                    <div class="space-y-2 text-center">
                        <GlowEffect
                            color="primary"
                            intensity="sm"
                            className="bg-primary-400 p-4 font-mono font-bold text-black md:p-6"
                        >
                            SM
                        </GlowEffect>
                        <span class="text-word-400 font-mono text-xs"
                            >Small</span
                        >
                    </div>
                    <div class="space-y-2 text-center">
                        <GlowEffect
                            color="primary"
                            intensity="md"
                            className="bg-primary-400 p-4 font-mono font-bold text-black md:p-6"
                        >
                            MD
                        </GlowEffect>
                        <span class="text-word-400 font-mono text-xs"
                            >Medium</span
                        >
                    </div>
                    <div class="space-y-2 text-center">
                        <GlowEffect
                            color="primary"
                            intensity="lg"
                            className="bg-primary-400 p-4 font-mono font-bold text-black md:p-6"
                        >
                            LG
                        </GlowEffect>
                        <span class="text-word-400 font-mono text-xs"
                            >Large</span
                        >
                    </div>
                </div>
            </Card>
        </section>

        <!-- Footer -->
        <footer
            class="border-secondary-800 border-t px-4 pt-6 text-center md:px-0 md:pt-8"
        >
            <p class="text-word-400 font-mono text-xs md:text-sm">
                IRON TRACK — Voltage Industrial Design System v1.0
            </p>
        </footer>
    </main>
</Layout>
