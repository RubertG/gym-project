---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="IRON TRACK - Components">
    <main class="bg-background-900 min-h-screen p-8">
        <!-- Nav -->
        <nav class="border-secondary-800 mb-8 flex gap-4 border-b pb-4">
            <a
                href="/design-system"
                class="text-word-400 hover:text-word-200 font-mono text-sm tracking-widest uppercase transition-colors"
            >
                Palette
            </a>
            <a
                href="/design-system/components"
                class="text-primary-400 font-mono text-sm tracking-widest uppercase"
            >
                Components
            </a>
        </nav>

        <!-- Header -->
        <header class="animate-fade-in-up mb-12">
            <h1
                class="font-display text-primary-400 text-5xl font-bold tracking-tighter"
            >
                COMPONENTS
            </h1>
            <p class="font-body text-word-200 mt-2 text-xl">
                Reusable React UI Components — IRON TRACK
            </p>
        </header>

        <!-- Button Component Section -->
        <section class="animate-fade-in-up mb-16">
            <h2
                class="font-display text-word-100 mb-4 text-2xl font-bold tracking-widest uppercase"
            >
                Button
            </h2>
            <div class="card-glass space-y-8 p-8">
                <!-- Variants -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-sm tracking-widest uppercase"
                    >
                        Variants
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <button class="btn-primary">Primary</button>
                        <button class="btn-secondary">Secondary</button>
                        <button
                            class="text-word-200 hover:border-secondary-400 border-2 border-transparent bg-transparent px-6 py-3 font-bold transition-all duration-200 hover:text-white"
                        >
                            Ghost
                        </button>
                        <button
                            class="border-2 border-red-600 bg-red-600 px-6 py-3 font-bold text-white transition-all duration-200 hover:border-red-500 hover:bg-red-500"
                        >
                            Danger
                        </button>
                    </div>
                </div>

                <!-- Sizes -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-sm tracking-widest uppercase"
                    >
                        Sizes
                    </h3>
                    <div class="flex flex-wrap items-center gap-4">
                        <button class="btn-primary px-4 py-2 text-sm"
                            >Small</button
                        >
                        <button class="btn-primary">Medium</button>
                        <button class="btn-primary px-8 py-4 text-lg"
                            >Large</button
                        >
                    </div>
                </div>

                <!-- States -->
                <div class="space-y-4">
                    <h3
                        class="text-word-400 font-mono text-sm tracking-widest uppercase"
                    >
                        States
                    </h3>
                    <div class="flex flex-wrap gap-4">
                        <button class="btn-primary">Default</button>
                        <button
                            class="btn-primary cursor-not-allowed opacity-50"
                            disabled
                        >
                            Disabled
                        </button>
                        <button class="btn-primary glow-primary"
                            >With Glow</button
                        >
                    </div>
                </div>
            </div>
        </section>

        <!-- Input Component Section -->
        <section class="animate-fade-in-up mb-16">
            <h2
                class="font-display text-word-100 mb-4 text-2xl font-bold tracking-widest uppercase"
            >
                Input
            </h2>
            <div class="card-glass space-y-8 p-8">
                <!-- Default -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-sm tracking-widest uppercase"
                    >
                        Default
                    </h3>
                    <label
                        class="text-word-300 mb-2 block font-mono text-xs font-bold tracking-widest uppercase"
                    >
                        Workout Name
                    </label>
                    <input
                        type="text"
                        placeholder="Enter your workout name..."
                        class="input-field"
                    />
                </div>

                <!-- With Error -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-sm tracking-widest uppercase"
                    >
                        With Error
                    </h3>
                    <label
                        class="text-word-300 mb-2 block font-mono text-xs font-bold tracking-widest uppercase"
                    >
                        Email <span class="text-primary-400 ml-1">*</span>
                    </label>
                    <input
                        type="email"
                        placeholder="your@email.com"
                        class="input-field border-red-500"
                        value="invalid-email"
                    />
                    <p class="mt-1 text-sm text-red-500">
                        Please enter a valid email address
                    </p>
                </div>

                <!-- Ghost Variant -->
                <div class="max-w-md space-y-4">
                    <h3
                        class="text-word-400 font-mono text-sm tracking-widest uppercase"
                    >
                        Ghost Variant
                    </h3>
                    <input
                        type="text"
                        placeholder="Search exercises..."
                        class="border-secondary-700 text-word-100 placeholder:text-word-400 focus:border-primary-400 w-full rounded-none border-0 border-b-2 bg-transparent px-0 py-2 transition-colors focus:outline-none"
                    />
                </div>
            </div>
        </section>

        <!-- Glow Effect Section -->
        <section class="animate-fade-in-up mb-16">
            <h2
                class="font-display text-word-100 mb-4 text-2xl font-bold tracking-widest uppercase"
            >
                Glow Effect
            </h2>
            <div class="card-glass space-y-8 p-8">
                <div class="flex flex-wrap gap-8">
                    <div class="space-y-2 text-center">
                        <div
                            class="bg-primary-400 p-6 font-mono font-bold text-black shadow-[0_0_15px_rgba(204,255,0,0.15)]"
                        >
                            SM
                        </div>
                        <span class="text-word-400 font-mono text-xs"
                            >Small</span
                        >
                    </div>
                    <div class="space-y-2 text-center">
                        <div
                            class="glow-primary bg-primary-400 p-6 font-mono font-bold text-black"
                        >
                            MD
                        </div>
                        <span class="text-word-400 font-mono text-xs"
                            >Medium</span
                        >
                    </div>
                    <div class="space-y-2 text-center">
                        <div
                            class="bg-primary-400 p-6 font-mono font-bold text-black shadow-[0_0_40px_rgba(204,255,0,0.5)]"
                        >
                            LG
                        </div>
                        <span class="text-word-400 font-mono text-xs"
                            >Large</span
                        >
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="border-secondary-800 border-t pt-8 text-center">
            <p class="text-word-400 font-mono text-sm">
                IRON TRACK — Voltage Industrial Design System v1.0
            </p>
        </footer>
    </main>
</Layout>
