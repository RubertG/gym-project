---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IRON TRACK - Voltage Industrial">
  <main class="min-h-screen">
    <!-- Hero Section - Primary Inverted -->
    <section
      class="animate-fade-in-up bg-primary-300 flex min-h-screen flex-col items-center justify-center p-8 text-center"
    >
      <h1
        class="font-display text-background-900 text-6xl font-black tracking-tighter md:text-8xl"
      >
        IRON TRACK
      </h1>
      <p
        class="font-body text-background-700 mt-4 max-w-2xl text-xl leading-relaxed md:text-2xl"
      >
        Industrial Brutalism meets Cyber-Minimalism. Track your workouts with
        precision and style.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/design-system"
          class="bg-background-900 text-word-100 border-background-900 hover:bg-background-800 border-2 px-8 py-4 font-bold transition-all duration-200"
        >
          Explore Design System
        </a>
        <a
          href="/design-system/components"
          class="text-background-900 border-background-900 hover:bg-background-900 hover:text-word-100 border-2 bg-transparent px-8 py-4 font-bold transition-all duration-200"
        >
          View Components
        </a>
      </div>
    </section>

    <!-- Features Section - Dark -->
    <section class="bg-background-900 px-8 py-24">
      <div class="mx-auto max-w-6xl">
        <h2
          class="font-display text-primary-400 mb-12 text-center text-4xl font-bold tracking-tighter"
        >
          FEATURES
        </h2>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div class="card-glass p-8">
            <span
              class="text-word-400 font-mono text-xs tracking-widest uppercase"
              >01</span
            >
            <h3 class="font-display text-word-100 mt-2 text-2xl font-bold">
              Track Workouts
            </h3>
            <p class="font-body text-word-300 mt-4 leading-relaxed">
              Log sets, reps, and weight with precision. Batch entry per
              exercise for efficiency.
            </p>
          </div>
          <div class="card-glass p-8">
            <span
              class="text-word-400 font-mono text-xs tracking-widest uppercase"
              >02</span
            >
            <h3 class="font-display text-word-100 mt-2 text-2xl font-bold">
              Visualize Progress
            </h3>
            <p class="font-body text-word-300 mt-4 leading-relaxed">
              Charts and graphs showing your strength evolution over time. PR
              tracking included.
            </p>
          </div>
          <div class="card-glass p-8">
            <span
              class="text-word-400 font-mono text-xs tracking-widest uppercase"
              >03</span
            >
            <h3 class="font-display text-word-100 mt-2 text-2xl font-bold">
              Community
            </h3>
            <p class="font-body text-word-300 mt-4 leading-relaxed">
              Share routines, discover new exercises, and build your gym
              network.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Inverted Section - Primary Background -->
    <section class="bg-primary-400 px-8 py-24">
      <div class="mx-auto max-w-4xl text-center">
        <h2
          class="font-display text-background-900 text-4xl font-bold tracking-tighter md:text-5xl"
        >
          VOLTAGE INDUSTRIAL
        </h2>
        <p class="font-body text-background-800 mt-6 text-xl leading-relaxed">
          Our design system fuses Industrial Brutalism with Cyber-Minimalism.
          Sharp edges, electric lime accents, and absolute darkness create an
          interface built for heavy use.
        </p>
        <div class="mt-8">
          <a
            href="/design-system"
            class="bg-background-900 text-word-100 border-background-900 hover:bg-background-800 inline-block border-2 px-8 py-4 font-bold transition-all duration-200"
          >
            View Full Palette
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section - Dark with Glow -->
    <section class="bg-background-900 px-8 py-24">
      <div class="glow-primary card-glass mx-auto max-w-3xl p-12 text-center">
        <h2
          class="font-display text-primary-400 text-3xl font-bold tracking-tighter md:text-4xl"
        >
          READY TO LIFT?
        </h2>
        <p class="font-body text-word-300 mt-4 text-lg">
          Start tracking your gains with the most brutal workout app on the web.
        </p>
        <div class="mt-8">
          <a href="/design-system/components" class="btn-primary inline-block">
            Get Started
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-secondary-800 bg-background-900 border-t px-8 py-12">
      <div class="mx-auto max-w-6xl">
        <div
          class="flex flex-col items-center justify-between gap-4 md:flex-row"
        >
          <p class="text-word-400 font-mono text-sm">
            IRON TRACK — Voltage Industrial Design System v1.0
          </p>
          <nav class="flex gap-6">
            <a
              href="/design-system"
              class="text-word-400 hover:text-primary-400 font-mono text-sm uppercase transition-colors"
              >Palette</a
            >
            <a
              href="/design-system/components"
              class="text-word-400 hover:text-primary-400 font-mono text-sm uppercase transition-colors"
              >Components</a
            >
          </nav>
        </div>
      </div>
    </footer>
  </main>
</Layout>
