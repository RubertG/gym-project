---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IRON TRACK - Voltage Industrial">
  <main
    class="flex min-h-screen flex-col items-center justify-center gap-8 p-8"
  >
    <h1
      class="font-display text-primary-400 animate-fade-in-up text-5xl font-bold"
    >
      IRON TRACK
    </h1>

    <div
      class="animate-fade-in-up flex flex-wrap gap-4"
      style="animation-delay: 0.1s;"
    >
      <button class="btn-primary">Start Workout</button>
      <button class="btn-secondary">View History</button>
    </div>

    <div
      class="animate-fade-in-up w-full max-w-md"
      style="animation-delay: 0.2s;"
    >
      <input
        type="text"
        placeholder="Search exercises..."
        class="input-field"
      />
    </div>

    <div
      class="card-glass animate-fade-in-up w-full max-w-md p-6"
      style="animation-delay: 0.3s;"
    >
      <h2 class="font-display text-primary-400 mb-2 text-xl font-bold">
        Voltage Industrial
      </h2>
      <p class="text-secondary-300 font-body">
        Industrial Brutalism + Cyber-Minimalism design system for the IRON TRACK
        gym workout tracking app.
      </p>
    </div>

    <div
      class="glow-primary bg-primary-400 animate-fade-in-up p-6 font-mono font-bold text-black"
      style="animation-delay: 0.4s;"
    >
      GLOW TEST
    </div>
  </main>
</Layout>
