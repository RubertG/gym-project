---
import Layout from '@/layouts/Layout.astro';
import Card from '@/components/ui/Card.tsx';
import { Button } from '@/components';
import LandingHeader from '@/components/features/landing/LandingHeader.astro';
---

<Layout title="IRON TRACK - Voltage Industrial">
    <LandingHeader />

    <main class="min-h-screen pt-10">
        <!-- Hero Section - Dark -->
        <section
            class="animate-fade-in-up bg-background-900 flex h-dvh flex-col items-center justify-center p-4 pt-0 text-center md:p-8 md:pt-0"
        >
            <h1
                class="font-display text-primary-400 text-4xl font-black tracking-tighter sm:text-5xl md:text-6xl lg:text-8xl"
            >
                IRON TRACK
            </h1>
            <p
                class="font-body text-word-200 mt-4 max-w-2xl text-lg leading-relaxed md:text-xl lg:text-2xl"
            >
                El Brutalismo Industrial se une al Ciber-Minimalismo. Registra
                tus entrenamientos con precisión y estilo.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-4">
                <Button
                    href="/design-system"
                    variant="primary"
                    className="inline-block"
                    client:load
                >
                    Explorar Design System
                </Button>
                <Button
                    href="/design-system/components"
                    variant="secondary"
                    className="inline-block"
                    client:load
                >
                    Ver Componentes
                </Button>
            </div>
        </section>

        <!-- Inverted Section - Primary Background -->
        <section class="bg-primary-400 px-4 py-16 md:px-8 md:py-24">
            <div class="mx-auto max-w-4xl text-center">
                <h2
                    class="font-display text-background-900 text-3xl font-bold tracking-tighter md:text-4xl lg:text-5xl"
                >
                    VOLTAGE INDUSTRIAL
                </h2>
                <p
                    class="font-body text-background-800 mt-6 text-lg leading-relaxed md:text-xl"
                >
                    Nuestro design system fusiona el Brutalismo Industrial con
                    el Ciber-Minimalismo. Bordes afilados, acentos verde lima
                    eléctrico y oscuridad absoluta crean una interfaz diseñada
                    para el uso intenso.
                </p>
                <div class="mt-8">
                    <Button
                        href="/design-system"
                        variant="primary"
                        surface="light"
                        className="border-background-900 bg-background-900 text-word-100 hover:bg-background-800 inline-block border-2"
                        client:load
                    >
                        Ver Paleta Completa
                    </Button>
                </div>
            </div>
        </section>

        <!-- Features Section - Dark -->
        <section class="bg-background-900 px-4 py-16 md:px-8 md:py-24">
            <div class="mx-auto max-w-6xl">
                <h2
                    class="font-display text-primary-400 mb-8 text-center text-3xl font-bold tracking-tighter md:mb-12 md:text-4xl"
                >
                    CARACTERÍSTICAS
                </h2>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
                    <Card className="p-6 md:p-8">
                        <span
                            class="text-word-400 font-mono text-xs tracking-widest uppercase"
                            >01</span
                        >
                        <h3
                            class="font-display text-word-100 mt-2 text-xl font-bold md:text-2xl"
                        >
                            Registra tus Entrenamientos
                        </h3>
                        <p class="font-body text-word-300 mt-4 leading-relaxed">
                            Anota series, repeticiones y peso con precisión.
                            Entrada por lotes por ejercicio para mayor
                            eficiencia.
                        </p>
                    </Card>
                    <Card className="p-6 md:p-8">
                        <span
                            class="text-word-400 font-mono text-xs tracking-widest uppercase"
                            >02</span
                        >
                        <h3
                            class="font-display text-word-100 mt-2 text-xl font-bold md:text-2xl"
                        >
                            Visualiza tu Progreso
                        </h3>
                        <p class="font-body text-word-300 mt-4 leading-relaxed">
                            Gráficas que muestran tu evolución de fuerza a lo
                            largo del tiempo. Seguimiento de récords incluido.
                        </p>
                    </Card>
                    <Card className="p-6 md:p-8">
                        <span
                            class="text-word-400 font-mono text-xs tracking-widest uppercase"
                            >03</span
                        >
                        <h3
                            class="font-display text-word-100 mt-2 text-xl font-bold md:text-2xl"
                        >
                            Comunidad
                        </h3>
                        <p class="font-body text-word-300 mt-4 leading-relaxed">
                            Comparte rutinas, descubre nuevos ejercicios y
                            construye tu red de gimnasio.
                        </p>
                    </Card>
                </div>
            </div>
        </section>

        <!-- CTA Section - Dark with Glow -->
        <section class="bg-background-900 px-4 py-16 md:px-8 md:py-24">
            <Card className="mx-auto max-w-3xl p-6 text-center md:p-10 lg:p-12">
                <h2
                    class="font-display text-primary-400 text-2xl font-bold tracking-tighter md:text-3xl lg:text-4xl"
                >
                    ¿LISTO PARA ENTRENAR?
                </h2>
                <p class="font-body text-word-300 mt-4 text-base md:text-lg">
                    Empieza a registrar tus avances con la app de entrenamiento
                    más brutal de la web.
                </p>
                <div class="mt-8">
                    <Button
                        href="/design-system/components"
                        variant="primary"
                        className="inline-block"
                        client:load
                    >
                        Comenzar
                    </Button>
                </div>
            </Card>
        </section>

        <!-- Footer -->
        <footer
            class="border-secondary-800 bg-background-900 border-t px-4 py-8 md:px-8 md:py-12"
        >
            <div class="mx-auto max-w-6xl">
                <div
                    class="flex flex-col items-center justify-between gap-4 md:flex-row"
                >
                    <p class="text-word-400 font-mono text-sm">
                        IRON TRACK — Voltage Industrial Design System v1.0
                    </p>
                    <nav class="flex gap-6">
                        <a
                            href="/design-system"
                            class="text-word-400 hover:text-primary-400 font-mono text-sm uppercase transition-colors"
                            >Paleta</a
                        >
                        <a
                            href="/design-system/components"
                            class="text-word-400 hover:text-primary-400 font-mono text-sm uppercase transition-colors"
                            >Componentes</a
                        >
                    </nav>
                </div>
            </div>
        </footer>
    </main>
</Layout>
