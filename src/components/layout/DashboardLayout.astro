---
/**
 * DashboardLayout — Layout protegido con sidebar + navbar.
 * Desktop: sidebar visible (256px) + main content.
 * Mobile: sidebar oculto, hamburger toggle, main full width.
 */

import Layout from '@/layouts/Layout.astro';
import Sidebar from './Sidebar.astro';
import Navbar from './Navbar.astro';

interface Props {
    title?: string;
}

const { title = 'Dashboard — IRON TRACK' } = Astro.props;

const user = Astro.locals.user;
const profile = Astro.locals.profile;
const currentPath = Astro.url.pathname;
---

<Layout title={title}>
    <div class="bg-background-900 flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <Sidebar currentPath={currentPath} />

        <!-- Main content area -->
        <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
            <!-- Navbar -->
            <Navbar user={user} profile={profile} />

            <!-- Page content -->
            <main class="flex-1 overflow-y-auto p-4 lg:p-6">
                <slot />
            </main>
        </div>
    </div>
</Layout>
