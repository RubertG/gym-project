---
/**
 * LandingHeader — Container Astro del header de la landing.
 * El fondo/blur/fixed viven aqui para evitar que ClientRouter
 * pierda los estilos durante transiciones.
 */

import { LandingNavbar } from './LandingNavbar'

const user = Astro.locals.user
const profile = Astro.locals.profile
---

<header
    class="bg-background-900/80 border-secondary-800/30 fixed top-0 z-40 w-full border-b backdrop-blur-xl"
>
    <LandingNavbar user={user} profile={profile} client:load />
</header>
